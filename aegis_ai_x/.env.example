# ============================================
# SUMONIX AI - Environment Configuration
# ============================================

# --- General ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production
APP_NAME=SUMONIX AI

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sumonix_ai
POSTGRES_USER=sumonix
POSTGRES_PASSWORD=change-me

# --- Database (MongoDB) ---
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=sumonix_ai_logs
MONGO_USER=sumonix
MONGO_PASSWORD=change-me

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# --- Auth ---
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# --- LLM Providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# --- Stripe (Payment) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Vector DB (Qdrant) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# --- Monitoring ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# --- API Gateway ---
API_GATEWAY_PORT=8000
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=60
